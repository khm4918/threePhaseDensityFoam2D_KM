FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      E.orig;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    symmetryX
    {
        type            symmetry;
    }
	
	symmetryY
	{
		type			symmetry;
	}

	innerWall
	{
		type	zeroGradient;
	}

	outerWall
	{
		type	zeroGradient;
	}

    front
    {
        type            empty;
    }
	
	back
	{
		type	empty;
	}
}

// ************************************************************************* //
